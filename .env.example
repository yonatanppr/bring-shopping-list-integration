# Bring account credentials. Prefer a dedicated account shared onto the target list.
BRING_EMAIL=
BRING_PASSWORD=

# Set one selector when the account has multiple lists. UUID is the stable choice.
#BRING_LIST_UUID=
#BRING_LIST_NAME=Groceries

# Live tests require both values and refuse to use the normal default list.
#BRING_RUN_LIVE_TESTS=1
#BRING_TEST_LIST_UUID=

# Total timeout for one HTTP request, in seconds.
BRING_REQUEST_TIMEOUT_SECONDS=20

# Remote deployment. Generate with deploy/bootstrap.sh; never reuse this example value.
#MCP_CAPABILITY=64-lowercase-hex-characters
#MCP_HTTP_MAX_BODY_BYTES=1048576
#MCP_HTTP_RATE_PER_MINUTE=120
#MCP_HTTP_RATE_BURST=30
#MCP_HTTP_MAX_CONCURRENCY=4
#TAILSCALE_HOSTNAME=bring-shopping
#BRING_SHOPPING_IMAGE=ghcr.io/yonatanppr/bring-shopping-list-integration:1.1.0
